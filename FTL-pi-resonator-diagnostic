    # update collective["intent"], warp_counter, etc.
    # -------------------------------------------

    # APPEND NEW BEAD (ensure this is in your real tick)
    bead_chain.append(new_bead)

    # UPDATE last_mode ON COLLECTIVE (optional convenience)
    index = (len(bead_chain) - 1) % len(d)
