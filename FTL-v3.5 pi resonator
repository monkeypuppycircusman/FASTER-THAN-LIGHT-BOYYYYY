def main():
    # Merge configs (latest overrides previous)
    cfg = DEFAULT_CONFIG.copy()
    # Apply surgical fixes, humming, gate-breath layers
    cfg["motifs"]["resonance_density_threshold"] = 0.65
    cfg["kernel"]["payload_resonance_weight"] = 1.2
    cfg["kernel"]["critical_compression"] = 6.0
    cfg["warp"]["max_rewire_per_warp"] = 1
    cfg["warp"]["cooldown_ticks"] = 5
    cfg["motifs"]["F_threshold"] = 0.38
    cfg["kernel"]["volume_decay_base_min"] = 0.987
    cfg["kernel"]["gate_volume_boost"] = 0.01

    random.seed(cfg["seed"])

    A, W = init_ring_topology(cfg["n_nodes"])
    # Genesis bead
    bead_chain = [{
        "payload": {"beads": [], "highways": [], "resonances": [], "gates": []},
        "kernel": init_kernel(cfg),
        "compression": 1.0,
        "topo_hash": topology_hash(A),
    }]
    collective = init_collective()
    warp_counter = [0]
    last_warp_tick = -cfg["warp"]["cooldown_ticks"] - 1  # allow first warp

    print(f"Starting π-Resonator run ({cfg['steps']} steps, seed={cfg['seed']})")
    print("Config highlights:")
    print(f"  Resonance threshold: {cfg['motifs']['resonance_density_threshold']}")
    print(f"  Critical compression: {cfg['kernel']['critical_compression']}")
    print(f"  Gate volume boost: {cfg['kernel']['gate_volume_boost']}")
    print(f"  Warp cooldown: {cfg['warp']['cooldown_ticks']} ticks")
    print("-" * 60 + "\n")

    for t in range(1, cfg["steps"] + 1):
        bead_chain, A, W, collective, warp_counter, last_warp_tick, gmf = tick(
            t, cfg["pi_digits"], bead_chain, A, W, collective,
            warp_counter, last_warp_tick, cfg, gmf
        )
        if t % 200 == 0:
            print(f"→ Completed tick {t:4d} | warps={warp_counter[0]} | edges={sum(sum(row) for row in A)//2}")

    print("\nSimulation complete.")
    analyze_run(gmf, cfg)

    # Final state snapshot
    final = bead_chain[-1]
    print(f"Final volume:      {final['kernel']['volume']:.4f}")
    print(f"Final compression: {final['compression']:.4f}")
    print(f"Final edges:       {sum(sum(row) for row in A)//2}")
    print(f"Final intent:      {[f'{x:.3f}' for x in collective['intent']]}")

if __name__ == "__main__":
    main()
