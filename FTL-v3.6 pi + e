    bead_chain = [{
        "payload": {"beads": [], "highways": [], "resonances": [], "gates": []},
        "kernel": init_kernel(CONFIG),
        "compression": 1.0,
        "topo_hash": topology_hash(A),
    }]
    collective = init_collective()
    warp_counter = [0]
    last_warp_tick = -CONFIG["warp"]["cooldown_ticks"] - 1

    for t in range(1, CONFIG["steps"] + 1):
        bead_chain, A, W, collective, warp_counter, last_warp_tick, gmf = tick(
            t, CONFIG, bead_chain, A, W, collective, warp_counter, last_warp_tick, gmf
        )
        if t % 200 == 0:
            print(f"→ t={t:4d} | warps={warp_counter[0]} | edges={sum(sum(row) for row in A)//2}")

    print("\nSimulation finished.")
    analyze_run(gmf, CONFIG)

    final = bead_chain[-1]
    print(f"Final volume:      {final['kernel']['volume']:.4f}")
    print(f"Final compression: {final['compression']:.4f}")
    print(f"Final edges:       {sum(sum(row) for row in A)//2}")
    print(f"Final intent:      {[f'{x:.3f}' for x in collective['intent']]}")
