# ============================================================
# FTL Operator v0.1 — Single Trigger (tight-shear jump)
# ============================================================

# Definition:
#   FTL(i) → j
#   j = next index where L[j] < 50

function FTL_jump_v01(i, L):
    for j = i+1 to N:
        if L[j] < 50:
            return j
    return N


# ============================================================
# FTL Operator v0.2 — Multi-Trigger (choose earliest)
# ============================================================

# Triggers:
#   1. Tight shear: L < 50
#   2. High F spike: F[j] > mean(F) + 2*std(F)
#   3. Flip transition: (d[j-1], d[j]) ∈ FLIP_SET
#   4. Neutral reset: L ≈ 1/φ²

function FTL_jump_v02(i, L, F, d):
    μF = mean(F)
    σF = std(F)

    for j = i+1 to N:

        # Tight shear
        if L[j] < 50:
            return j

        # High F spike
        if F[j] > μF + 2*σF:
            return j

        # Flip transition
        if (d[j-1], d[j]) in FLIP_SET:
            return j

        # Neutral reset
        if abs(L[j] - 0.382) < 0.001:
            return j

    return N


# ============================================================
# FTL + Breathing Gate Fusion (phase-locked jump)
# ============================================================

# Only allow FTL jump when oscillator is in open window:
#   |R(t)| / R_max < τ_open
#   AND v(t) > v_boost threshold

function FTL_phase_locked(i, t, L, F, d):
    if |R(t)|/R_max < τ_open and v(t) > v_boost:
        return FTL_jump_v02(i, L, F, d)
    else:
        return i + 1   # normal step


